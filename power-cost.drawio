  <diagram id="jpmGnkbDbl4J7M9V5PJR" name="Page-7">
    <mxGraphModel dx="736" dy="449" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Power_Cost_Tracker_ERD\n\nskinparam linetype ortho\nskinparam shadowing false\nskinparam classBackgroundColor #F9F9F9\nskinparam classBorderColor #333333\n\ntitle Power Cost Tracker - Refined Relational Database Schema (Supabase/PostgreSQL)\n\n!define table(x) class x &lt;&lt; (T,#FFAAAA) &gt;&gt;\n!define pk(x) &lt;b&gt;&lt;color:#b30000&gt;x&lt;/color&gt;&lt;/b&gt;\n!define fk(x) &lt;color:#0047b3&gt;x&lt;/color&gt;\n\n&#39;====================================================\n&#39; ENUM TYPES (PostgreSQL)\n&#39;====================================================\n\nenum power_source_type {\n    GRID\n    GENERATOR\n    SOLAR\n}\n\nenum power_event_type {\n    FUEL_ADDED\n    SOURCE_SWITCH\n    MAINTENANCE\n}\n\nenum sync_status {\n    SAVED_LOCAL\n    SYNCING\n    SYNCED\n    FAILED\n}\n\n&#39;====================================================\n&#39; TABLES\n&#39;====================================================\n\ntable(businesses) {\n    pk(id) : UUID\n    --\n    name : VARCHAR(255)\n    currency : VARCHAR(3)\n    created_at : TIMESTAMPTZ\n}\n\ntable(power_sources) {\n    pk(id) : UUID\n    --\n    fk(business_id) : UUID\n    name : VARCHAR(255)\n    type : power_source_type\n\n    tank_capacity_litres : NUMERIC(10,2)\n    consumption_rate_lph : NUMERIC(10,2)\n    generator_kva_rating : NUMERIC(10,2)\n\n    utility_provider : VARCHAR(255)\n    meter_number : VARCHAR(100)\n\n    battery_capacity_ah : NUMERIC(10,2)\n    inverter_kva_rating : NUMERIC(10,2)\n    panel_wattage : NUMERIC(10,2)\n}\n\ntable(power_readings) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    timestamp : TIMESTAMPTZ\n\n    runtime_hours : NUMERIC(10,2)\n    current_fuel_level_litres : NUMERIC(10,2)\n\n    meter_reading_kwh : NUMERIC(12,2)\n    active_phase_count : INTEGER\n\n    battery_soc_percent : INTEGER\n    pv_generation_watts : NUMERIC(12,2)\n    active_load_watts : NUMERIC(12,2)\n\n    --\n    UNIQUE(source_id, timestamp)\n}\n\ntable(power_events) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    timestamp : TIMESTAMPTZ\n    event_type : power_event_type\n    notes : TEXT\n}\n\ntable(fuel_added_events) {\n    pk(event_id) : UUID\n    --\n    litres_added : NUMERIC(10,2)\n    price_per_litre : NUMERIC(10,2)\n}\n\ntable(source_switch_events) {\n    pk(event_id) : UUID\n    --\n    fk(from_source_id) : UUID\n    fk(to_source_id) : UUID\n}\n\ntable(maintenance_events) {\n    pk(event_id) : UUID\n    --\n    description : TEXT\n    maintenance_cost : NUMERIC(12,2)\n}\n\ntable(tariffs) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    name : VARCHAR(255)\n    cost_per_unit : NUMERIC(10,2)\n    effective_from : TIMESTAMPTZ\n    effective_to : TIMESTAMPTZ\n    metadata : JSONB\n}\n\ntable(usage_logs) {\n    pk(id) : UUID\n    --\n    fk(business_id) : UUID\n    fk(start_reading_id) : UUID\n    fk(end_reading_id) : UUID\n    fk(trigger_event_id) : UUID\n\n    total_calculated_cost : NUMERIC(12,2)\n\n    sync_status : sync_status\n\n    notes : TEXT\n\n    created_by_user_id : UUID\n\n    created_at : TIMESTAMPTZ\n    audited_at : TIMESTAMPTZ\n}\n\n&#39;====================================================\n&#39; RELATIONSHIPS\n&#39;====================================================\n\nbusinesses \&quot;1\&quot; -- \&quot;1..*\&quot; power_sources\n\nbusinesses \&quot;1\&quot; -- \&quot;0..*\&quot; usage_logs\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; power_readings\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; power_events\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; tariffs\n\npower_events ||--|| fuel_added_events\n\npower_events ||--|| source_switch_events\n\npower_events ||--|| maintenance_events\n\nusage_logs --&gt; power_readings : start_reading\n\nusage_logs --&gt; power_readings : end_reading\n\nusage_logs --&gt; power_events : triggered_by\n\nsource_switch_events --&gt; power_sources : from_source\n\nsource_switch_events --&gt; power_sources : to_source\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="cN66QWKLlSMoKBM-naAG-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="999" width="1142" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;pre&gt;                                                        ┌───────────────────────────────────────┐                                                                           &#xa;┌─────────────────┐  ┌────────────────┐                 │businesses                             │                                                                           &#xa;│power_source_type│  │power_event_type│                 ├───────────────────────────────────────┤                                                                           &#xa;├─────────────────┤  ├────────────────┤                 │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID│                                                                           &#xa;│GRID             │  │FUEL_ADDED      │                 │--                                     │                                                                           &#xa;│GENERATOR        │  │SOURCE_SWITCH   │                 │name : VARCHAR(255)                    │                                                                           &#xa;│SOLAR            │  │MAINTENANCE     │                 │currency : VARCHAR(3)                  │                                                                           &#xa;└─────────────────┘  └────────────────┘                 │created_at : TIMESTAMPTZ               │                                                                           &#xa;                                                        └───────────────────────────────────────┘                                                                           &#xa;                                                                                                                                                                            &#xa;                                                                                                                                                                            &#xa;                                    ┌──────────────────────────────────────────────┐              ┌─────────────────────────────────────────┐                               &#xa;                                    │usage_logs                                    │              │power_sources                            │                               &#xa;                                    ├──────────────────────────────────────────────┤              ├─────────────────────────────────────────┤                               &#xa;                                    │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID       │              │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID  │                               &#xa;                                    │--                                            │              │--                                       │                               &#xa;                                    │&lt;color:#0047b3&gt;business_id&lt;/color&gt; : UUID     │              │&lt;color:#0047b3&gt;business_id&lt;/color&gt; : UUID│                               &#xa;   ┌───────────┐                    │&lt;color:#0047b3&gt;start_reading_id&lt;/color&gt; : UUID│              │name : VARCHAR(255)                      │                               &#xa;   │sync_status│                    │&lt;color:#0047b3&gt;end_reading_id&lt;/color&gt; : UUID  │              │type : power_source_type                 │                               &#xa;   ├───────────┤                    │&lt;color:#0047b3&gt;trigger_event_id&lt;/color&gt; : UUID│              │                                         │                               &#xa;   │SAVED_LOCAL│                    │                                              │              │tank_capacity_litres : NUMERIC(10,2)     │                               &#xa;   │SYNCING    │                    │total_calculated_cost : NUMERIC(12,2)         │              │consumption_rate_lph : NUMERIC(10,2)     │                               &#xa;   │SYNCED     │                    │                                              │              │generator_kva_rating : NUMERIC(10,2)     │                               &#xa;   │FAILED     │                    │sync_status : sync_status                     │              │                                         │                               &#xa;   └───────────┘                    │                                              │              │utility_provider : VARCHAR(255)          │                               &#xa;                                    │notes : TEXT                                  │              │meter_number : VARCHAR(100)              │                               &#xa;                                    │                                              │              │                                         │                               &#xa;                                    │created_by_user_id : UUID                     │              │battery_capacity_ah : NUMERIC(10,2)      │                               &#xa;                                    │                                              │              │inverter_kva_rating : NUMERIC(10,2)      │                               &#xa;                                    │created_at : TIMESTAMPTZ                      │              │panel_wattage : NUMERIC(10,2)            │                               &#xa;                                    │audited_at : TIMESTAMPTZ                      │              └─────────────────────────────────────────┘                               &#xa;                                    └──────────────────────────────────────────────┘                                                                                        &#xa;                                                                                                                                                                            &#xa;                                ┌─────────────────────────────────────────┐                                                                                                 &#xa;                                │power_readings                           │                                                                                                 &#xa;                                ├─────────────────────────────────────────┤                                                                                                 &#xa;                                │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID  │                                                                                                 &#xa;                                │--                                       │                                                                                                 &#xa;                                │&lt;color:#0047b3&gt;source_id&lt;/color&gt; : UUID  │                                                        ┌───────────────────────────────────────┐&#xa;                                │timestamp : TIMESTAMPTZ                  │   ┌───────────────────────────────────────┐            │tariffs                                │&#xa;                                │                                         │   │power_events                           │            ├───────────────────────────────────────┤&#xa;                                │runtime_hours : NUMERIC(10,2)            │   ├───────────────────────────────────────┤            │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID│&#xa;                                │current_fuel_level_litres : NUMERIC(10,2)│   │&lt;b&gt;&lt;color:#b30000&gt;id&lt;/color&gt;&lt;/b&gt; : UUID│            │--                                     │&#xa;                                │                                         │   │--                                     │            │&lt;color:#0047b3&gt;source_id&lt;/color&gt; : UUID│&#xa;                                │meter_reading_kwh : NUMERIC(12,2)        │   │&lt;color:#0047b3&gt;source_id&lt;/color&gt; : UUID│            │name : VARCHAR(255)                    │&#xa;                                │active_phase_count : INTEGER             │   │timestamp : TIMESTAMPTZ                │            │cost_per_unit : NUMERIC(10,2)          │&#xa;                                │                                         │   │event_type : power_event_type          │            │effective_from : TIMESTAMPTZ           │&#xa;                                │battery_soc_percent : INTEGER            │   │notes : TEXT                           │            │effective_to : TIMESTAMPTZ             │&#xa;                                │pv_generation_watts : NUMERIC(12,2)      │   └───────────────────────────────────────┘            │metadata : JSONB                       │&#xa;                                │active_load_watts : NUMERIC(12,2)        │                                                        └───────────────────────────────────────┘&#xa;                                │                                         │                                                                                                 &#xa;                                │--                                       │                                                                                                 &#xa;                                │UNIQUE(source_id, timestamp)             │                                                                                                 &#xa;                                └─────────────────────────────────────────┘                                                                                                 &#xa;                                                                                                                                                                            &#xa;                                                                                                                                                                            &#xa;  ┌─────────────────────────────────────────────┐   ┌─────────────────────────────────────────────┐   ┌─────────────────────────────────────────────┐                       &#xa;  │maintenance_events                           │   │fuel_added_events                            │   │source_switch_events                         │                       &#xa;  ├─────────────────────────────────────────────┤   ├─────────────────────────────────────────────┤   ├─────────────────────────────────────────────┤                       &#xa;  │&lt;b&gt;&lt;color:#b30000&gt;event_id&lt;/color&gt;&lt;/b&gt; : UUID│   │&lt;b&gt;&lt;color:#b30000&gt;event_id&lt;/color&gt;&lt;/b&gt; : UUID│   │&lt;b&gt;&lt;color:#b30000&gt;event_id&lt;/color&gt;&lt;/b&gt; : UUID│                       &#xa;  │--                                           │   │--                                           │   │--                                           │                       &#xa;  │description : TEXT                           │   │litres_added : NUMERIC(10,2)                 │   │&lt;color:#0047b3&gt;from_source_id&lt;/color&gt; : UUID │                       &#xa;  │maintenance_cost : NUMERIC(12,2)             │   │price_per_litre : NUMERIC(10,2)              │   │&lt;color:#0047b3&gt;to_source_id&lt;/color&gt; : UUID   │                       &#xa;  └─────────────────────────────────────────────┘   └─────────────────────────────────────────────┘   └─────────────────────────────────────────────┘                       &#xa;&lt;/pre&gt;" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Power_Cost_Tracker_ERD\n\nskinparam linetype ortho\nskinparam shadowing false\nskinparam classBackgroundColor #F9F9F9\nskinparam classBorderColor #333333\n\ntitle Power Cost Tracker - Refined Relational Database Schema (Supabase/PostgreSQL)\n\n!define table(x) class x &lt;&lt; (T,#FFAAAA) &gt;&gt;\n!define pk(x) &lt;b&gt;&lt;color:#b30000&gt;x&lt;/color&gt;&lt;/b&gt;\n!define fk(x) &lt;color:#0047b3&gt;x&lt;/color&gt;\n\n&#39;====================================================\n&#39; ENUM TYPES (PostgreSQL)\n&#39;====================================================\n\nenum power_source_type {\n    GRID\n    GENERATOR\n    SOLAR\n}\n\nenum power_event_type {\n    FUEL_ADDED\n    SOURCE_SWITCH\n    MAINTENANCE\n}\n\nenum sync_status {\n    SAVED_LOCAL\n    SYNCING\n    SYNCED\n    FAILED\n}\n\n&#39;====================================================\n&#39; TABLES\n&#39;====================================================\n\ntable(businesses) {\n    pk(id) : UUID\n    --\n    name : VARCHAR(255)\n    currency : VARCHAR(3)\n    created_at : TIMESTAMPTZ\n}\n\ntable(power_sources) {\n    pk(id) : UUID\n    --\n    fk(business_id) : UUID\n    name : VARCHAR(255)\n    type : power_source_type\n\n    tank_capacity_litres : NUMERIC(10,2)\n    consumption_rate_lph : NUMERIC(10,2)\n    generator_kva_rating : NUMERIC(10,2)\n\n    utility_provider : VARCHAR(255)\n    meter_number : VARCHAR(100)\n\n    battery_capacity_ah : NUMERIC(10,2)\n    inverter_kva_rating : NUMERIC(10,2)\n    panel_wattage : NUMERIC(10,2)\n}\n\ntable(power_readings) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    timestamp : TIMESTAMPTZ\n\n    runtime_hours : NUMERIC(10,2)\n    current_fuel_level_litres : NUMERIC(10,2)\n\n    meter_reading_kwh : NUMERIC(12,2)\n    active_phase_count : INTEGER\n\n    battery_soc_percent : INTEGER\n    pv_generation_watts : NUMERIC(12,2)\n    active_load_watts : NUMERIC(12,2)\n\n    --\n    UNIQUE(source_id, timestamp)\n}\n\ntable(power_events) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    timestamp : TIMESTAMPTZ\n    event_type : power_event_type\n    notes : TEXT\n}\n\ntable(fuel_added_events) {\n    pk(event_id) : UUID\n    --\n    litres_added : NUMERIC(10,2)\n    price_per_litre : NUMERIC(10,2)\n}\n\ntable(source_switch_events) {\n    pk(event_id) : UUID\n    --\n    fk(from_source_id) : UUID\n    fk(to_source_id) : UUID\n}\n\ntable(maintenance_events) {\n    pk(event_id) : UUID\n    --\n    description : TEXT\n    maintenance_cost : NUMERIC(12,2)\n}\n\ntable(tariffs) {\n    pk(id) : UUID\n    --\n    fk(source_id) : UUID\n    name : VARCHAR(255)\n    cost_per_unit : NUMERIC(10,2)\n    effective_from : TIMESTAMPTZ\n    effective_to : TIMESTAMPTZ\n    metadata : JSONB\n}\n\ntable(usage_logs) {\n    pk(id) : UUID\n    --\n    fk(business_id) : UUID\n    fk(start_reading_id) : UUID\n    fk(end_reading_id) : UUID\n    fk(trigger_event_id) : UUID\n\n    total_calculated_cost : NUMERIC(12,2)\n\n    sync_status : sync_status\n\n    notes : TEXT\n\n    created_by_user_id : UUID\n\n    created_at : TIMESTAMPTZ\n    audited_at : TIMESTAMPTZ\n}\n\n&#39;====================================================\n&#39; RELATIONSHIPS\n&#39;====================================================\n\nbusinesses \&quot;1\&quot; -- \&quot;1..*\&quot; power_sources\n\nbusinesses \&quot;1\&quot; -- \&quot;0..*\&quot; usage_logs\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; power_readings\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; power_events\n\npower_sources \&quot;1\&quot; -- \&quot;0..*\&quot; tariffs\n\npower_events ||--|| fuel_added_events\n\npower_events ||--|| source_switch_events\n\npower_events ||--|| maintenance_events\n\nusage_logs --&gt; power_readings : start_reading\n\nusage_logs --&gt; power_readings : end_reading\n\nusage_logs --&gt; power_events : triggered_by\n\nsource_switch_events --&gt; power_sources : from_source\n\nsource_switch_events --&gt; power_sources : to_source\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;txt&quot;&#xa;}" id="cN66QWKLlSMoKBM-naAG-4">
          <mxCell parent="1" style="text;html=1;align=left;verticalAlign=top;" vertex="1">
            <mxGeometry height="960" width="1160" x="80" y="1120" as="geometry" />
